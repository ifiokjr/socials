{
  "name": "@social/publisher",
  "version": "0.1.0",
  "exports": "./src/main.ts",
  "tasks": {
    "dev": "deno run -A --unstable-kv src/main.ts",
    "dev:vite": "deno run -A npm:vite",
    "build": "deno run -A npm:vite build",
    "preview": "deno run -A npm:vite preview",
    "test": "deno test -A --parallel --unstable-kv",
    "test:e2e": "deno run -A npm:playwright test",
    "test:e2e:install": "deno run -A npm:playwright install --with-deps chromium",
    "lint": "deno lint",
    "fmt": "deno fmt",
    "check": "deno check src/**/*.ts"
  },
  "imports": {
    "@hono/hono": "jsr:@hono/hono@^4",
    "@std/assert": "jsr:@std/assert@^1",
    "@std/async": "jsr:@std/async@^1",
    "@std/collections": "jsr:@std/collections@^1",
    "@std/datetime": "jsr:@std/datetime@^0",
    "@std/dotenv": "jsr:@std/dotenv@^0",
    "@std/encoding": "jsr:@std/encoding@^1",
    "@std/fmt": "jsr:@std/fmt@^1",
    "@std/fs": "jsr:@std/fs@^1",
    "@std/http": "jsr:@std/http@^1",
    "@std/log": "jsr:@std/log@^0",
    "@std/path": "jsr:@std/path@^1",
    "@std/streams": "jsr:@std/streams@^1",
    "@std/text": "jsr:@std/text@^1",
    "@std/yaml": "jsr:@std/yaml@^1",
    "@std/crypto": "jsr:@std/crypto@^1"
  },
  "unstable": ["kv"],
  "compilerOptions": {
    "lib": ["deno.window", "deno.unstable", "dom", "dom.iterable"],
    "strict": true
  },
  "fmt": {
    "useTabs": false,
    "lineWidth": 100,
    "indentWidth": 2,
    "singleQuote": false
  },
  "lint": {
    "rules": {
      "tags": ["recommended"]
    }
  },
  "exclude": [
    "node_modules",
    "dist",
    "test-results",
    "playwright-report"
  ],
  "nodeModulesDir": "auto"
}
